            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "If WhatsApp number": {
      "main": [
        [
          {
            "node": "Build Message",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Respond",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Message": {
      "main": [
        [
          {
            "node": "Send WhatsApp (Cloud API)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send WhatsApp (Cloud API)": {
      "main": [
        [
          {
            "node": "Respond",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
